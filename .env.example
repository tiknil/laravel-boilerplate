APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_URL=http://local.website.it

## DOCKER CONFIGURATIONS
SERVER_ALIAS=local.website.it
SERVER_PORT=8888
SERVER_SSL_PORT=4443
DOCKER_HOST_IP=10.0.75.1

# DB CONFIGS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# Redis configs
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

# Api configs
API_PREFIX=api
API_SUBTYPE=website
API_STANDARDS_TREE=vnd
API_DEBUG=true
API_VERSION=v1
API_STRICT=false

# S3 configs
AWS_KEY=aws_key
AWS_SECRET=aws_secret
AWS_REGION=eu-west-1
AWS_BUCKET=website.local.bucket

# BUGSNAG
BUGSNAG_API_KEY=bugsnag_api_key
BUGSNAG_NOTIFY_RELEASE_STAGES=development,production